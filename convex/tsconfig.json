{
  /* This TypeScript project config describes the environment that
   * Convex functions run in and is used to typecheck them.
   * You can modify it, but some settings are required to use Convex.
   */
  "compilerOptions": {
    /* These settings are not required by Convex and can be modified. */
    "allowJs": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Resolve the project's `@/*` path alias (mirrors the root tsconfig) so the
     * Convex typecheck can follow imports from convex/*.ts into ../src/** where
     * modules reference each other via `@/modules/...`. Without this, `convex
     * codegen`/`dev`/`deploy` typecheck fails with TS2307 on every `@/` import. */
    "baseUrl": "..",
    "paths": { "@/*": ["src/*"] },

    /* These compiler options are required by Convex */
    "target": "ESNext",
    "lib": ["ES2023", "dom"],
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
