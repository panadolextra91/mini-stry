{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mini-stry.local/schema/policy-content.json",
  "title": "PolicyContent",
  "description": "Mini-stry Policy Runtime Core — canonical PolicyContent schema (Phase 2, D-23).",
  "type": "object",
  "additionalProperties": false,
  "required": ["rules", "defaultDecision"],
  "properties": {
    "rules": { "type": "array", "items": { "$ref": "#/$defs/rule" } },
    "defaultDecision": { "$ref": "#/$defs/decision" }
  },
  "$defs": {
    "ruleId": { "type": "string", "minLength": 1 },
    "field": { "type": "string", "minLength": 1 },
    "operator": { "enum": ["eq","neq","gt","gte","lt","lte","contains","in"] },
    "jsonScalar": { "type": ["string","number","boolean","null"] },
    "jsonValue": {
      "oneOf": [
        { "$ref": "#/$defs/jsonScalar" },
        { "type": "array", "items": { "$ref": "#/$defs/jsonScalar" } }
      ]
    },
    "comparePredicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type","field","op","value"],
      "properties": {
        "type":  { "const": "compare" },
        "field": { "$ref": "#/$defs/field" },
        "op":    { "$ref": "#/$defs/operator" },
        "value": { "$ref": "#/$defs/jsonValue" }
      },
      "allOf": [
        { "if": { "properties": { "op": { "const": "in" } } },
          "then": { "properties": { "value": { "type": "array" } } } },
        { "if": { "properties": { "op": { "enum": ["gt","gte","lt","lte"] } } },
          "then": { "properties": { "value": { "type": "number" } } } },
        { "if": { "properties": { "op": { "const": "contains" } } },
          "then": { "properties": { "value": { "type": "string" } } } }
      ]
    },
    "predicate": {
      "oneOf": [ { "$ref": "#/$defs/comparePredicate" } ]
    },
    "decision": {
      "oneOf": [
        { "type": "object", "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "auto-approve" } } },
        { "type": "object", "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "auto-reject" } } },
        { "type": "object", "additionalProperties": false,
          "required": ["kind","targetRoleId"],
          "properties": {
            "kind": { "const": "request-approval" },
            "targetRoleId": { "type": "string", "minLength": 1 }
          } }
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id","when","decision"],
      "properties": {
        "id":       { "$ref": "#/$defs/ruleId" },
        "when":     { "$ref": "#/$defs/predicate" },
        "decision": { "$ref": "#/$defs/decision" }
      }
    }
  }
}
